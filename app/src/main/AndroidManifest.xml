<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />

    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:label="Chrome Redirector"
        android:supportsRtl="true">
        
        <activity
            android:name=".RedirectActivity"
            android:exported="true"
            android:theme="@style/Theme.Transparent"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="http" />
                <data android:scheme="https" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.google.android.apps.chrome.webapps.WebappManager.ACTION_START_WEBAPP" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <activity
            android:name=".SettingsActivity"
            android:label="Redirector Settings"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity-alias
            android:name="com.google.android.apps.chrome.webapps.WebappActivity"
            android:targetActivity=".RedirectActivity"
            android:exported="true" />

        <activity-alias
            android:name="org.chromium.chrome.browser.webapps.WebappLauncherActivity"
            android:targetActivity=".RedirectActivity"
            android:exported="true" />
        <receiver
            android:name=".PushForwarder"
            android:exported="true"
            android:permission="com.google.android.c2dm.permission.SEND">
            <intent-filter>
                <action android:name="com.google.android.c2dm.intent.RECEIVE" />
                <category android:name="com.android.chrome" />
            </intent-filter>
            <!-- Catch any other Chrome specific webapp updates just in case -->
            <intent-filter>
                <action android:name="org.chromium.chrome.browser.webapps.WebappManager.ACTION_UPDATE_WEBAPP" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
